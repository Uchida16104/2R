---
title: 2R System Architecture
---

graph TD
    Client["Frontend\nVue 3 + HTMX + Alpine.js + Hyperscript\nTailwind CSS"]
    LocalDB[("Offline Storage\nPouchDB / IndexedDB\nSQL.js / localStorage")]
    Nginx["Nginx\nReverse Proxy :80"]
    Laravel["Laravel 11\nAPI Gateway & Orchestrator\n:9000 PHP-FPM"]
    MainDB[("PostgreSQL 16\nAuthoritative Store\n:5432")]
    AuthRust["auth_rust\nAxum / Rust\nAvailability :3001"]
    BookingNet["booking_dotnet\nASP.NET 8 / C#\nEnterprise Calendar :5001"]
    VerifyDafny["verify_dafny\nDafny + Python Bridge\nFormal Verification :3002"]
    AnalyticsPy["analytics_python\nFastAPI / asyncpg\nUsage & Forecast :8001"]
    PerfCpp["perf_cpp\nC++20 Raw Sockets\nSlot Resolver :9001"]
    SysZig["sys_zig\nZig 0.13\nSystem Validator :9002"]
    AiMojo["ai_mojo\nMojo / Python fallback\nAI Forecast :8002"]
    FormalFstar["formal_fstar\nF* Proof Spec\n(Offline Verification)"]
    LegacyGas["legacy_gas\nGoogle Apps Script\nCalendar Sync"]
    LegacyVba["legacy_vba\nVBA / Office COM\nExcel Sync"]

    Client -->|"HTTPS REST"| Nginx
    Client <-->|"Offline Queue"| LocalDB
    LocalDB -.->|"Eventual Consistency\non reconnect"| Laravel
    Nginx --> Laravel
    Laravel <--> MainDB
    Laravel -->|"Availability check"| AuthRust
    AuthRust <--> MainDB
    Laravel -->|"Enterprise calendar"| BookingNet
    BookingNet <--> MainDB
    Laravel -->|"Invariant proof"| VerifyDafny
    Laravel -->|"Usage analytics"| AnalyticsPy
    AnalyticsPy <--> MainDB
    Laravel -->|"Slot resolution"| PerfCpp
    Laravel -->|"Field validation"| SysZig
    Laravel -->|"AI forecast"| AiMojo
    FormalFstar -.->|"Spec used by"| VerifyDafny
    LegacyGas -->|"POST /api/reservations"| Nginx
    LegacyVba -->|"POST /api/reservations"| Nginx

